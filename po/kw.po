msgid "Login Preview"
msgstr "Ragwolok Omgelmi"

#: data/io.github.Foldex.AdwSteamGtk.desktop.in:4
msgid "A simple wrapper that installs Adwaita for Steam"
msgstr "Unn app sempel dre lea Adwaita rag Steam"

